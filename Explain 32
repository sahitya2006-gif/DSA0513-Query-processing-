# 2. Scatter plot of trading volume / stock price between two dates
import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv("alphabet_stock_data.csv")
df['Date'] = pd.to_datetime(df['Date'])

data = df[(df['Date'] >= '2016-10-01') & (df['Date'] <= '2016-10-31')]

plt.scatter(data['Volume'], data['Close'])
plt.xlabel("Volume")
plt.ylabel("Stock Price")
plt.title("Volume vs Stock Price")
plt.show()
