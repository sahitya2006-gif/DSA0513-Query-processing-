#Highlight negative numbers red and positive numbers black
import pandas as pd
import numpy as np

df = pd.DataFrame(np.random.randn(10,4), columns=['A','B','C','D'])

def color(val):
    if val < 0:
        return 'color:red'
    else:
        return 'color:black'

styled = df.style.applymap(color)

print(styled)
