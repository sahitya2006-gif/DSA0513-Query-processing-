# Bar plot of Alphabet Inc. trading volume between two dates
import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv("alphabet_stock_data.csv")
df['Date'] = pd.to_datetime(df['Date'])

data = df[(df['Date'] >= '2016-10-01') & (df['Date'] <= '2016-10-31')]

data.plot(x='Date', y='Volume', kind='bar')
plt.title("Alphabet Trading Volume")
plt.show()
